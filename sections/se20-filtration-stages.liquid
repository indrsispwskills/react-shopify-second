<!-- ═══ FILTER — 5-Stage ═══ -->
<section id="filter" class="sec" style="padding:36px 28px;background:linear-gradient(145deg,var(--cream),#fff);border-radius:28px;border:1px solid var(--bdr);box-shadow:var(--sh-sm);position:relative;overflow:hidden">
  <div class="particles"><span style="--x:85%;--y:10%;--tx:-20px;--ty:30px;--s:4px;--c:rgba(94,138,106,.08);--d:5s;--dl:0s"></span><span style="--x:10%;--y:90%;--tx:30px;--ty:-20px;--s:3px;--c:rgba(176,134,66,.06);--d:6s;--dl:2s"></span></div>
  <div class="sh rv" style="position:relative;z-index:1"><div class="tag" style="color:var(--sage)">THE FILTER</div><h2>5-Stage Filtration</h2><p>This is not random layering. This is a sequential stress-removal architecture — each stage targets a specific class of threat.</p></div>
  <div id="filtGrid" style="position:relative;z-index:1">
    <div class="filt-card" data-c="sage">
      <div class="filt-num" style="background:var(--sage3);color:var(--sage)">1</div>
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:12px"><div class="filt-ico" style="background:var(--sage3);animation:gentlePulse 3s ease-in-out infinite;flex-shrink:0">🪨</div><div><h4 style="font-size:17px;margin-bottom:2px">Stage 1: Sediment Pre-Filter</h4><p class="fd" style="font-size:14px;color:var(--light);margin:0">Catches rust, sand, particulate matter, pipe debris — reduces micro-barrier disruption</p></div></div>
      <div class="cr fd"><svg class="chk" viewBox="0 0 18 18"><circle cx="9" cy="9" r="9" fill="var(--sage)" opacity=".12"/><path d="M5.5 9l2.5 2.5 4.5-4.5" stroke="var(--sage)" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg><span style="font-size:14px">Catches rust, sand, and pipe debris before they touch your skin</span></div>
      <div class="filt-eff"><div class="filt-eff-fill" data-w="99" style="background:linear-gradient(90deg,var(--sage),#A8D5B5)"></div></div>
      <div style="display:flex;justify-content:space-between;font-size:14px;margin-top:5px"><span style="color:var(--mut)">Sediment Capture</span><span style="font-weight:700;color:var(--sage)">99%</span></div>
      <div class="filt-tag" style="padding:12px 16px;border-radius:12px;background:var(--sage3);font-size:14px;color:var(--sage);line-height:1.5;margin-top:14px"><strong>Why at 45+:</strong> Prevents micro-scratching on fragile, thinning cuticles.</div>
    </div>
    <div class="filt-card" data-c="gold">
      <div class="filt-num" style="background:var(--gold3);color:var(--gold)">2</div>
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:12px"><div class="filt-ico" style="background:var(--gold3);animation:gentlePulse 3s ease-in-out infinite .5s;flex-shrink:0">⚗️</div><div><h4 style="font-size:17px;margin-bottom:2px">Stage 2: Calcium Sulfite</h4><p class="fd" style="font-size:14px;color:var(--light);margin:0">Rapid chlorine neutralization — converts free chlorine into harmless chloride salts in hot water</p></div></div>
      <div class="cr fd"><svg class="chk" viewBox="0 0 18 18"><circle cx="9" cy="9" r="9" fill="var(--gold)" opacity=".12"/><path d="M5.5 9l2.5 2.5 4.5-4.5" stroke="var(--gold)" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg><span style="font-size:14px">Neutralizes chlorine, heavy metals, and bacteria through electrochemical reaction</span></div>
      <div class="filt-eff"><div class="filt-eff-fill" data-w="90" style="background:linear-gradient(90deg,var(--gold),#D4AA7D)"></div></div>
      <div style="display:flex;justify-content:space-between;font-size:14px;margin-top:5px"><span style="color:var(--mut)">Chlorine Removal</span><span style="font-weight:700;color:var(--gold)">90%+</span></div>
      <div class="filt-tag" style="padding:12px 16px;border-radius:12px;background:var(--gold3);font-size:14px;color:var(--gold);line-height:1.5;margin-top:14px"><strong>The big one:</strong> Stops daily oil-stripping that compounds hormonal dryness.</div>
    </div>
    <div class="filt-card" data-c="ink">
      <div class="filt-num" style="background:rgba(27,58,75,.08);color:var(--navy)">3</div>
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:12px"><div class="filt-ico" style="background:rgba(27,58,75,.06);animation:gentlePulse 3s ease-in-out infinite 1s;flex-shrink:0">🌿</div><div><h4 style="font-size:17px;margin-bottom:2px">Stage 3: Vitamin C (Sodium Ascorbate)</h4><p class="fd" style="font-size:14px;color:var(--light);margin:0">Secondary chlorine + chloramine neutralization — environmental antioxidant defense</p></div></div>
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:12px"><div class="filt-ico" style="background:rgba(70,130,180,.06);animation:gentlePulse 3s ease-in-out infinite 1.5s;flex-shrink:0">⚗️</div><div><h4 style="font-size:17px;margin-bottom:2px">Stage 4: KDF-55 Copper-Zinc Media</h4><p class="fd" style="font-size:14px;color:var(--light);margin:0">Electrochemical redox removes heavy metals (lead, mercury, nickel), suppresses bacterial biofilm</p></div></div>
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:12px"><div class="filt-ico" style="background:rgba(123,31,162,.06);animation:gentlePulse 3s ease-in-out infinite 2s;flex-shrink:0">🌿</div><div><h4 style="font-size:17px;margin-bottom:2px">Stage 5: Catalytic Activated Carbon</h4><p class="fd" style="font-size:14px;color:var(--light);margin:0">Engineered for chloramines, VOCs, PFAS traces — persistent irritants standard carbon misses</p></div></div>
      <div class="cr fd"><svg class="chk" viewBox="0 0 18 18"><circle cx="9" cy="9" r="9" fill="var(--navy)" opacity=".1"/><path d="M5.5 9l2.5 2.5 4.5-4.5" stroke="var(--navy)" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg><span style="font-size:14px">Adsorbs VOCs, odors, and residual compounds for clean, soft water</span></div>
      <div class="filt-eff"><div class="filt-eff-fill" data-w="85" style="background:linear-gradient(90deg,var(--navy),#2D5A6B)"></div></div>
      <div style="display:flex;justify-content:space-between;font-size:14px;margin-top:5px"><span style="color:var(--mut)">VOC Reduction</span><span style="font-weight:700;color:var(--navy)">85%</span></div>
      <div class="filt-tag" style="padding:12px 16px;border-radius:12px;background:rgba(27,58,75,.05);font-size:14px;color:var(--navy);line-height:1.5;margin-top:14px"><strong>The polish:</strong> Water that genuinely smells and feels clean.</div>
    </div>
  </div>

  <!-- 5.0 Upgrade Callout -->
  <div class="rv rv-d3" style="margin-top:20px;padding:22px;border-radius:18px;background:linear-gradient(135deg,var(--sage3),#fff);border:1px solid rgba(94,138,106,.12);box-shadow:var(--sh-sm);position:relative;z-index:1">
    <div style="display:flex;gap:16px;align-items:center;flex-wrap:wrap">
      <div style="flex-shrink:0;text-align:center;padding:16px;border-radius:14px;background:#fff;border:1px solid var(--bdr);animation:glowPulse 4s ease-in-out infinite"><div style="font-family:var(--fh);font-size:28px;font-weight:700;color:var(--gold)">5×</div><div style="font-size:14px;color:var(--mut);font-weight:600">More Stages</div></div>
      <div style="flex:1;min-width:200px"><h4 style="font-size:17px;margin-bottom:6px">Need Deeper Protection?</h4><p style="font-size:14px;color:var(--mut);line-height:1.6;margin:0">The <strong>5.0 Stationary</strong> adds 12 more stages — targeting chloramines, fluoride, heavy metals + pH correction. For women who want the full protocol.</p></div>
    </div>
  <!-- Filter Cross-Section Diagram -->
  <div class="rv" style="margin-top:28px;border:2px dashed rgba(176,134,66,.4);border-radius:24px;padding:36px 28px;background:rgba(176,134,66,.03);display:flex;flex-direction:column;align-items:center;gap:12px;text-align:center;max-width:600px;margin-left:auto;margin-right:auto;position:relative;z-index:1">
    <span style="font-size:36px;opacity:.4">🔬</span>
    <span style="font-size:14px;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:.06em">5-Stage Filter Cross-Section</span>
    <span style="font-size:14px;color:var(--gold);opacity:.5">Upload cutaway illustration showing all 3 filtration layers</span>
  </div>
</section>

<!-- ═══ WHAT'S IN THE BOX ═══ -->
<section class="sec">
  <div class="sh rv"><div class="tag" style="color:var(--gold)">WHAT'S IN THE BOX</div><h2>Everything You Need — Nothing You Don't</h2></div>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;max-width:680px;margin:0 auto" class="img-ph-grid">
    <div class="rv rv-d1" style="padding:20px;border-radius:18px;background:#fff;border:1px solid var(--bdr);text-align:center;box-shadow:var(--sh-sm)">
      <div style="font-size:36px;margin-bottom:8px">🚿</div>
      <div style="font-size:14px;font-weight:600;color:var(--ink)">2.0 Handheld Head</div>
      <div style="font-size:14px;color:var(--mut)">3 spray modes</div>
    </div>
    <div class="rv rv-d2" style="padding:20px;border-radius:18px;background:#fff;border:1px solid var(--bdr);text-align:center;box-shadow:var(--sh-sm)">
      <div style="font-size:36px;margin-bottom:8px">🧲</div>
      <div style="font-size:14px;font-weight:600;color:var(--ink)">60″ Stainless Hose</div>
      <div style="font-size:14px;color:var(--mut)">Flexible reach</div>
    </div>
    <div class="rv rv-d3" style="padding:20px;border-radius:18px;background:#fff;border:1px solid var(--bdr);text-align:center;box-shadow:var(--sh-sm)">
      <div style="font-size:36px;margin-bottom:8px">⚗️</div>
      <div style="font-size:14px;font-weight:600;color:var(--ink)">5-Stage Filter</div>
      <div style="font-size:14px;color:var(--mut)">Pre-installed</div>
    </div>
    <div class="rv rv-d4" style="padding:20px;border-radius:18px;background:#fff;border:1px solid var(--bdr);text-align:center;box-shadow:var(--sh-sm)">
      <div style="font-size:36px;margin-bottom:8px">🪝</div>
      <div style="font-size:14px;font-weight:600;color:var(--ink)">Wall Bracket</div>
      <div style="font-size:14px;color:var(--mut)">Adjustable mount</div>
    </div>
    <div class="rv rv-d6" style="padding:20px;border-radius:18px;background:#fff;border:1px solid var(--bdr);text-align:center;box-shadow:var(--sh-sm)">
      <div style="font-size:36px;margin-bottom:8px">📖</div>
      <div style="font-size:14px;font-weight:600;color:var(--ink)">Quick-Start Guide</div>
      <div style="font-size:14px;color:var(--mut)">5-min install</div>
    </div>
  </div>
  <!-- Unboxing Photo Placeholder -->
  <div class="rv" style="margin-top:24px;border:2px dashed var(--gold);border-radius:20px;padding:32px 24px;background:rgba(176,134,66,.03);display:flex;flex-direction:column;align-items:center;gap:10px;text-align:center;max-width:500px;margin-left:auto;margin-right:auto">
    <span style="font-size:32px;opacity:.5">📦</span>
    <span style="font-size:14px;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:.04em">Unboxing Photo</span>
    <span style="font-size:14px;color:var(--gold);opacity:.5">Upload photo of open box with all items visible</span>
  </div>
</section>

<div class="divider rv"><span>✦</span></div>


