{% comment %}
  Custom cart drawer container used by custom add-to-cart buttons.
  Content is populated from /cart?section_id=cart-drawer by JS.
{% endcomment %}

<style>
  #CustomCartDrawer {
    position: fixed;
    inset: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: 1000;
  }

  #CustomCartDrawer.is-open {
    visibility: visible;
    pointer-events: auto;
  }

  #CustomCartDrawer .custom-cart-drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  #CustomCartDrawer.is-open .custom-cart-drawer__overlay {
    opacity: 1;
  }

  #CustomCartDrawer .custom-cart-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: min(42rem, 100vw);
    transform: translateX(100%);
    transition: transform 0.25s ease;
    background: rgb(var(--color-background));
  }

  #CustomCartDrawer.is-open .custom-cart-drawer__panel {
    transform: translateX(0);
  }
</style>

<div id="CustomCartDrawer" aria-hidden="true">
  <button class="custom-cart-drawer__overlay" type="button" aria-label="Close cart drawer"></button>
  <div class="custom-cart-drawer__panel" role="dialog" aria-modal="true" aria-label="Cart drawer" tabindex="-1">
    <div id="CustomCartDrawerContent"></div>
  </div>
</div>
