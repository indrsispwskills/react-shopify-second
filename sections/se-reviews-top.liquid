<div class="page">
  <nav class="topnav">
    <div style="display:flex;align-items:center;gap:24px">
      <a href="{{ section.settings.logo_link }}" class="logo">
        <svg class="brand-mark" width="24" height="24" viewBox="0 0 32 32" style="vertical-align:middle;margin-right:6px"><circle cx="16" cy="16" r="14" fill="var(--sage)" opacity=".12"/><path d="M16 8v5M12 16c0-2.2 1.8-4 4-4s4 1.8 4 4M13 19s1 3 3 3 3-3 3-3" stroke="var(--sage)" stroke-width="2" stroke-linecap="round" fill="none"/><circle cx="16" cy="24" r="1.2" fill="var(--sage)"/></svg>{{ section.settings.logo_text }}<span>{{ section.settings.logo_accent }}</span>
      </a>
      <div class="nav-links">
        {% for block in section.blocks %}
          <a href="{{ block.settings.link }}" {% if block.settings.active %}class="act"{% endif %}>{{ block.settings.label }}</a>
        {% endfor %}
      </div>
    </div>
    <a class="cart-btn" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
  </nav>

  <section class="hero rv">
    <div style="display:inline-block;padding:8px 20px;border-radius:20px;font-size:14px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--sage);background:var(--sage3);margin-bottom:20px">{{ section.settings.badge }}</div>
    <h1>{{ section.settings.title }}</h1>
    <p class="hero-sub">{{ section.settings.subtitle }}</p>

    <div class="stats-row rv rv-d1">
      <div class="stat">
        <div class="rating-stars">
          <svg viewBox="0 0 20 20"><path d="M10 1l2.8 5.6 6.2.9-4.5 4.4 1.1 6.1L10 15.4 4.4 18l1.1-6.1L1 7.5l6.2-.9L10 1z" fill="var(--gold)"/></svg>
          <svg viewBox="0 0 20 20"><path d="M10 1l2.8 5.6 6.2.9-4.5 4.4 1.1 6.1L10 15.4 4.4 18l1.1-6.1L1 7.5l6.2-.9L10 1z" fill="var(--gold)"/></svg>
          <svg viewBox="0 0 20 20"><path d="M10 1l2.8 5.6 6.2.9-4.5 4.4 1.1 6.1L10 15.4 4.4 18l1.1-6.1L1 7.5l6.2-.9L10 1z" fill="var(--gold)"/></svg>
          <svg viewBox="0 0 20 20"><path d="M10 1l2.8 5.6 6.2.9-4.5 4.4 1.1 6.1L10 15.4 4.4 18l1.1-6.1L1 7.5l6.2-.9L10 1z" fill="var(--gold)"/></svg>
          <svg viewBox="0 0 20 20"><path d="M10 1l2.8 5.6 6.2.9-4.5 4.4 1.1 6.1L10 15.4 4.4 18l1.1-6.1L1 7.5l6.2-.9L10 1z" fill="var(--gold)" opacity=".6"/></svg>
        </div>
        <div class="stat-num" style="color:var(--gold)">{{ section.settings.rating_value }}</div>
        <div class="stat-label">Average Rating</div>
      </div>
      <div class="stat"><div class="stat-num" style="color:var(--sage)">{{ section.settings.total_reviews }}</div><div class="stat-label">Verified Reviews</div></div>
      <div class="stat"><div class="stat-num" style="color:var(--ink)">{{ section.settings.recommend_pct }}</div><div class="stat-label">Would Recommend</div></div>
      <div class="stat"><div class="stat-num" style="color:var(--rose)">{{ section.settings.multi_buy }}</div><div class="stat-label">Bought Multiple Units</div></div>
    </div>

    <div class="hero-badges rv rv-d2">
      <span class="hero-badge">{{ section.settings.badge_1 }}</span>
      <span class="hero-badge">{{ section.settings.badge_2 }}</span>
      <span class="hero-badge">{{ section.settings.badge_3 }}</span>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "SE reviews top",
  "settings": [
    {"type":"text","id":"logo_text","label":"Logo text","default":"Shower"},
    {"type":"text","id":"logo_accent","label":"Logo accent","default":"Envy"},
    {"type":"url","id":"logo_link","label":"Logo link"},
    {"type":"text","id":"cta_label","label":"Top CTA label","default":"Shop Now"},
    {"type":"url","id":"cta_link","label":"Top CTA link"},
    {"type":"text","id":"badge","label":"Hero badge","default":"VERIFIED CUSTOMER REVIEWS"},
    {"type":"text","id":"title","label":"Hero title","default":"Real Women. Real Results."},
    {"type":"textarea","id":"subtitle","label":"Hero subtitle","default":"Every review is from a verified purchase. No incentives, no cherry-picking. These are honest experiences from women 45+ dealing with real hair, skin, and health challenges."},
    {"type":"text","id":"rating_value","label":"Rating value","default":"4.8"},
    {"type":"text","id":"total_reviews","label":"Total reviews","default":"1,347"},
    {"type":"text","id":"recommend_pct","label":"Recommend percent","default":"94%"},
    {"type":"text","id":"multi_buy","label":"Multi-buy count","default":"673"},
    {"type":"text","id":"badge_1","label":"Pill 1","default":"🏆 #1 Rated Filtered Showerhead for Women 45+"},
    {"type":"text","id":"badge_2","label":"Pill 2","default":"✅ All Reviews Verified by Purchase"},
    {"type":"text","id":"badge_3","label":"Pill 3","default":"📊 Avg. Age of Reviewer: 52"}
  ],
  "blocks": [
    {"type":"link","name":"Nav link","settings":[{"type":"text","id":"label","label":"Label","default":"Home"},{"type":"url","id":"link","label":"Link"},{"type":"checkbox","id":"active","label":"Active","default":false}]}
  ],
  "max_blocks": 8,
  "presets": [{"name":"SE reviews top","blocks":[{"type":"link","settings":{"label":"Home"}},{"type":"link","settings":{"label":"2.0 Handheld"}},{"type":"link","settings":{"label":"5.0 Stationary"}},{"type":"link","settings":{"label":"Science"}},{"type":"link","settings":{"label":"Reviews","active":true}}]}]
}
{% endschema %}
