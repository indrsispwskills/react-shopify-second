<!-- HERO -->
<section class="policy-hero rv">
  <div class="badge">{{ section.settings.badge_text }}</div>
  <h1>{{ section.settings.hero_title }}</h1>
  <p class="policy-hero-sub">{{ section.settings.hero_subtitle }}</p>
  <div class="updated">{{ section.settings.last_updated }}</div>
</section>

<!-- PROMISE BOX -->
<div class="promise-box rv rv-d1">
  <h3>🛡️ Our Privacy Promise to You</h3>
  <div class="promise-grid">
    <div class="promise-item"><div class="promise-icon">✓</div> We never sell your personal information. Ever.</div>
    <div class="promise-item"><div class="promise-icon">✓</div> We never share your data with advertisers.</div>
    <div class="promise-item"><div class="promise-icon">✓</div> We use bank-level encryption (256-bit SSL).</div>
    <div class="promise-item"><div class="promise-icon">✓</div> You can delete your data anytime — just ask.</div>
    <div class="promise-item"><div class="promise-icon">✓</div> We only collect what we need to serve you.</div>
    <div class="promise-item"><div class="promise-icon">✓</div> You'll never get surprise emails you didn't sign up for.</div>
  </div>
</div>

<!-- MAIN LAYOUT -->
<div class="policy-layout">

<!-- TOC -->
<aside>
  <div class="toc">
    <div class="toc-title">On this page</div>
    <a href="#who">Who We Are</a>
    <a href="#collect">What We Collect</a>
    <a href="#why">Why We Collect It</a>
    <a href="#never">What We Never Do</a>
    <a href="#cookies">Cookies</a>
    <a href="#sharing">Data Sharing</a>
    <a href="#security">Security</a>
    <a href="#rights">Your Rights</a>
    <a href="#children">Children's Privacy</a>
    <a href="#changes">Policy Changes</a>
    <a href="#contact">Contact Us</a>
  </div>
</aside>

<!-- CONTENT -->
<div class="content">

  <!-- WHO WE ARE -->
  <div class="policy-section rv" id="who">
    <div class="section-header">
      <div class="section-icon" style="background:var(--sage-light)">👋</div>
      <div><h2>Who We Are</h2><p>The real people behind ShowerEnvy</p></div>
    </div>
    <p>ShowerEnvy Technologies LLC is a woman-founded company based in Cheyenne, Wyoming. We design filtered showerheads specifically for women experiencing hormonal hair and skin changes — because we've been through it ourselves.</p>
    <p>When we say "ShowerEnvy," "we," "us," or "our" in this policy, we mean ShowerEnvy Technologies LLC and our website at showerenvy.com.</p>
    <div class="highlight-box">
      <p><strong>Our company details:</strong><br>ShowerEnvy Technologies LLC<br>Cheyenne, Wyoming 82001, USA<br>📧 <a href="mailto:hello@showerenvy.com">hello@showerenvy.com</a><br>📞 <a href="tel:+18339240099">+1 (833) 924-0099</a> · Mon–Fri 9 AM–5 PM EST</p>
    </div>
  </div>

  <!-- WHAT WE COLLECT -->
  <div class="policy-section rv" id="collect">
    <div class="section-header">
      <div class="section-icon" style="background:var(--gold-light)">📋</div>
      <div><h2>What We Collect</h2><p>Only what we genuinely need</p></div>
    </div>
    <p>We keep our data collection minimal. Here's everything we may collect and exactly why:</p>

    <p><strong>When you place an order:</strong></p>
    <ul class="plain-list">
      <li>Your name and email address (so we can confirm your order and reach you if there's an issue)</li>
      <li>Shipping address (so your 2.0 Handheld or 5.0 Stationary arrives at your door)</li>
      <li>Phone number (only if you provide it — for delivery notifications)</li>
      <li>Payment information (processed securely by Stripe — we never see or store your full card number)</li>
    </ul>

    <p><strong>When you visit our website:</strong></p>
    <ul class="plain-list">
      <li>Basic browsing data (pages visited, time spent — helps us improve your experience)</li>
      <li>Device type and browser (so our site looks great on your phone, tablet, or computer)</li>
      <li>IP address (required for security and fraud prevention)</li>
    </ul>

    <p><strong>When you contact us:</strong></p>
    <ul class="plain-list">
      <li>Your email or phone number (so we can respond)</li>
      <li>The content of your message (so we can actually help)</li>
    </ul>

    <div class="highlight-box">
      <p><strong>Plain-English summary:</strong> We collect your name, email, address, and payment info when you buy something. We see basic website activity. That's it. No health data, no invasive tracking, no social media snooping.</p>
    </div>
  </div>

  <!-- WHY WE COLLECT IT -->
  <div class="policy-section rv" id="why">
    <div class="section-header">
      <div class="section-icon" style="background:var(--sage-light)">💡</div>
      <div><h2>Why We Collect It</h2><p>Every piece of data has a clear purpose</p></div>
    </div>
    <ul class="plain-list">
      <li><strong>To fulfill your order</strong> — ship your showerhead, send tracking info, and process your payment</li>
      <li><strong>To provide customer support</strong> — answer questions about installation, filter replacements, or your subscription</li>
      <li><strong>To send order updates</strong> — shipping confirmations, delivery notifications, and subscription reminders (7 days before each filter shipment)</li>
      <li><strong>To improve our products</strong> — understanding which features matter most helps us build better showerheads</li>
      <li><strong>To prevent fraud</strong> — keeping transactions safe protects both you and us</li>
      <li><strong>To send marketing emails</strong> — only if you explicitly opt in, and you can unsubscribe with one click anytime</li>
    </ul>
  </div>

  <!-- WHAT WE NEVER DO -->
  <div class="policy-section rv" id="never">
    <div class="section-header">
      <div class="section-icon" style="background:#FEF2F2">🚫</div>
      <div><h2>What We Never Do</h2><p>Our firm commitments to you</p></div>
    </div>
    <p>This is the part we're most proud of. Here's what we will <strong>never</strong> do with your information:</p>
    <ul class="plain-list never-list">
      <li><strong>Sell your data to anyone.</strong> Not to advertisers, data brokers, or anyone else. Period.</li>
      <li><strong>Share your email with other companies</strong> so they can market to you.</li>
      <li><strong>Track your activity across other websites.</strong> What you do outside showerenvy.com is your business.</li>
      <li><strong>Collect sensitive health information.</strong> We know our products help with hormonal changes, but we don't ask for or store medical details.</li>
      <li><strong>Keep your data longer than necessary.</strong> If you ask us to delete it, we will — within 30 days.</li>
      <li><strong>Make it hard to unsubscribe.</strong> Every email has a one-click unsubscribe link. No guilt trips, no "are you sure?" pages.</li>
    </ul>
  </div>

  <!-- COOKIES -->
  <div class="policy-section rv" id="cookies">
    <div class="section-header">
      <div class="section-icon" style="background:var(--gold-light)">🍪</div>
      <div><h2>Cookies</h2><p>The digital kind (we wish they were chocolate)</p></div>
    </div>
    <p>Cookies are small files stored on your device that help our website work properly. Here's what we use:</p>

    <p><strong>Essential cookies (required):</strong> These keep your shopping cart working, remember your login, and maintain security. The site can't function without them.</p>

    <p><strong>Analytics cookies (optional):</strong> These help us understand how visitors use our site — like which pages are most popular or where people get stuck. We use this data in aggregate (not to identify individuals) to make the experience better for everyone.</p>

    <p><strong>Marketing cookies (optional):</strong> If you've opted in to marketing, these help us show you relevant content. You can disable these in your browser settings at any time.</p>

    <div class="highlight-box">
      <p><strong>How to control cookies:</strong> Most browsers let you block or delete cookies through their settings. Blocking essential cookies may affect your shopping experience, but analytics and marketing cookies can be disabled without any impact.</p>
    </div>
  </div>

  <!-- DATA SHARING -->
  <div class="policy-section rv" id="sharing">
    <div class="section-header">
      <div class="section-icon" style="background:var(--sage-light)">🤝</div>
      <div><h2>Who We Share Data With</h2><p>Only trusted partners who help us serve you</p></div>
    </div>
    <p>We work with a small number of carefully chosen partners. They only receive the minimum information needed to do their job:</p>
    <ul class="plain-list do-list">
      <li><strong>Stripe</strong> — Payment processing. They handle your card info under their own strict security standards. We never see your full card number.</li>
      <li><strong>Shipping carriers</strong> (USPS, UPS, FedEx) — Your name and address so your order arrives safely.</li>
      <li><strong>Email service provider</strong> — Your email address for order confirmations and (if you opted in) marketing emails.</li>
      <li><strong>Customer support tools</strong> — Your name, email, and message content so our team can help you efficiently.</li>
    </ul>
    <p>Each of these partners is contractually required to protect your data and prohibited from using it for their own marketing.</p>

    <div class="highlight-box gold">
      <p><strong>We may also share data if legally required</strong> — for example, in response to a valid court order or subpoena. If this ever happens, we'll notify you unless we're legally prohibited from doing so.</p>
    </div>
  </div>

  <!-- SECURITY -->
  <div class="policy-section rv" id="security">
    <div class="section-header">
      <div class="section-icon" style="background:var(--sage-light)">🔒</div>
      <div><h2>How We Protect Your Data</h2><p>Serious security, explained simply</p></div>
    </div>
    <ul class="plain-list do-list">
      <li><strong>256-bit SSL encryption</strong> on every page of our website — the same standard used by major banks.</li>
      <li><strong>PCI-compliant payment processing</strong> through Stripe — your card info never touches our servers.</li>
      <li><strong>Secure data storage</strong> with encrypted databases and strict access controls.</li>
      <li><strong>Regular security audits</strong> to identify and fix vulnerabilities.</li>
      <li><strong>Employee access limits</strong> — only team members who need data to do their job can access it.</li>
    </ul>
    <p>While no system is 100% immune to threats, we take every reasonable step to keep your information safe. If a breach ever did occur, we would notify affected customers within 72 hours.</p>
  </div>

  <!-- YOUR RIGHTS -->
  <div class="policy-section rv" id="rights">
    <div class="section-header">
      <div class="section-icon" style="background:var(--gold-light)">⚖️</div>
      <div><h2>Your Rights</h2><p>Your data, your control</p></div>
    </div>
    <p>Regardless of where you live, we believe you deserve these rights:</p>
    <ul class="plain-list">
      <li><strong>Right to know</strong> — Ask us what data we have about you, and we'll tell you within 30 days.</li>
      <li><strong>Right to correct</strong> — If something's wrong, let us know and we'll fix it.</li>
      <li><strong>Right to delete</strong> — Want us to erase your data? Just email us. Done within 30 days.</li>
      <li><strong>Right to export</strong> — Want a copy of your data? We'll send it in a common format.</li>
      <li><strong>Right to opt out</strong> — Unsubscribe from marketing anytime with one click.</li>
      <li><strong>Right to complain</strong> — If you're unhappy with how we handle your data, contact us or your local data protection authority.</li>
    </ul>
    <p>To exercise any of these rights, email <a href="mailto:hello@showerenvy.com">hello@showerenvy.com</a> with the subject line "Privacy Request." We'll respond within 5 business days.</p>
    <div class="highlight-box">
      <p><strong>For California residents (CCPA):</strong> You have additional rights under the California Consumer Privacy Act. We do not sell personal information. You may request disclosure of data collected in the prior 12 months. We will never discriminate against you for exercising your privacy rights.</p>
    </div>
  </div>

  <!-- CHILDREN -->
  <div class="policy-section rv" id="children">
    <div class="section-header">
      <div class="section-icon" style="background:#FEF2F2">👶</div>
      <div><h2>Children's Privacy</h2><p>Our site is for adults</p></div>
    </div>
    <p>ShowerEnvy products are designed for adults, and our website is not directed at children under 16. We do not knowingly collect personal information from children. If we learn that we have inadvertently collected data from a child, we will delete it promptly.</p>
  </div>

  <!-- CHANGES -->
  <div class="policy-section rv" id="changes">
    <div class="section-header">
      <div class="section-icon" style="background:var(--sage-light)">📝</div>
      <div><h2>Changes to This Policy</h2><p>We'll always let you know</p></div>
    </div>
    <p>If we make meaningful changes to this policy, we'll notify you by email at least 14 days before the changes take effect. Minor updates (like fixing a typo or clarifying language) won't require notification, but the "last updated" date at the top will always reflect the most current version.</p>
    <p>We will never reduce your rights without your explicit consent.</p>
  </div>

  <!-- CONTACT -->
  <div class="contact-card rv" id="contact">
    <h2>{{ section.settings.contact_title }}</h2>
    <p>{{ section.settings.contact_subtitle }}</p>
    <div class="contact-methods">
      <div class="contact-method">
        <div class="cm-icon">📧</div>
        <div class="cm-label">Email</div>
        <div class="cm-value"><a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a></div>
        <div class="cm-note">We respond within 24 hours</div>
      </div>
      <div class="contact-method">
        <div class="cm-icon">📞</div>
        <div class="cm-label">Phone</div>
        <div class="cm-value">{{ section.settings.contact_phone }}</div>
        <div class="cm-note">Mon–Fri, 9 AM–5 PM EST</div>
      </div>
      <div class="contact-method">
        <div class="cm-icon">📮</div>
        <div class="cm-label">Mail</div>
        <div class="cm-value">ShowerEnvy Technologies LLC</div>
        <div class="cm-note">Cheyenne, WY 82001</div>
      </div>
    </div>
  </div>

</div><!-- .content -->
</div><!-- .policy-layout -->


{% schema %}
{
  "name": "Privacy policy content",
  "settings": [
    {"type":"text","id":"badge_text","label":"Badge text","default":"YOUR PRIVACY MATTERS"},
    {"type":"text","id":"hero_title","label":"Hero title","default":"Privacy Policy"},
    {"type":"textarea","id":"hero_subtitle","label":"Hero subtitle","default":"We believe you deserve to know exactly what happens with your information — explained in plain English, not legal jargon."},
    {"type":"text","id":"last_updated","label":"Last updated label","default":"Last updated: February 15, 2026 · Effective immediately"},
    {"type":"text","id":"contact_title","label":"Contact title","default":"Questions About Your Privacy?"},
    {"type":"textarea","id":"contact_subtitle","label":"Contact subtitle","default":"Our team is real, human, and happy to help. No bots, no runaround."},
    {"type":"text","id":"contact_email","label":"Contact email","default":"hello@showerenvy.com"},
    {"type":"text","id":"contact_phone","label":"Contact phone","default":"+1 (833) 924-0099"}
  ],
  "presets":[{"name":"Privacy policy content"}]
}
{% endschema %}
