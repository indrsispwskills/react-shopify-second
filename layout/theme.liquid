<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.colors_solid_button_labels }}">
    <link rel="canonical" href="{{ canonical_url }}">
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}
    <title>{{ page_title }}{% if current_tags %} — {{ current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} — Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} — {{ shop.name }}{% endunless %}</title>
    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {{ 'responsive.css' | asset_url | stylesheet_tag }}
    {% if template.suffix == 'comparison' %}
      {{ 'comparison-2-vs-5.css' | asset_url | stylesheet_tag }}
      {{ 'comparison-2-vs-5-responsive.css' | asset_url | stylesheet_tag }}
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    {% endif %}

    {% if template.suffix == 'shower-envy-science' %}
      {{ 'shower-envy-science.css' | asset_url | stylesheet_tag }}
      {{ 'shower-envy-science-responsive.css' | asset_url | stylesheet_tag }}
      <link rel="preconnect" href="https://fonts.googleapis.com"> 
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    {% endif %}

    {% if template.suffix == 'shower-envy-reviews' %}
      {{ 'se-reviews.css' | asset_url | stylesheet_tag }}
      {{ 'se-reviews-responsive.css' | asset_url | stylesheet_tag }}
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    {% endif %}

    {% if template.suffix == 'water-report' %}
      {{ 'water-report.css' | asset_url | stylesheet_tag }}
      {{ 'water-report-responsive.css' | asset_url | stylesheet_tag }}
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    {% endif %}

    {% if template.suffix == 'refund-policy' %}
      {{ 'refund-policy.css' | asset_url | stylesheet_tag }}
      {{ 'refund-policy-responsive.css' | asset_url | stylesheet_tag }}
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    {% endif %}

    {% if template.suffix == 'privacy-policy' %}
      {{ 'privacy-policy.css' | asset_url | stylesheet_tag }}
      {{ 'privacy-policy-responsive.css' | asset_url | stylesheet_tag }}
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    {% endif %}

    {% if template.suffix == 'terms' %}
      {{ 'terms.css' | asset_url | stylesheet_tag }}
      {{ 'terms-responsive.css' | asset_url | stylesheet_tag }}
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    {% endif %}

    {% if template.suffix == 'showerenvy-5-0-stationary' %}
      {{ 'se50-stationary.css' | asset_url | stylesheet_tag }}
      {{ 'se50-stationary-responsive.css' | asset_url | stylesheet_tag }}
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    {% endif %}

    {% if template.suffix == 'showerenvy-2-product' %}
      {{ 'se20-product.css' | asset_url | stylesheet_tag }}
      {{ 'se20-product-responsive.css' | asset_url | stylesheet_tag }}
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    {% endif %}
{%- if settings.cart_type == 'drawer' -%}
      {{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}
      {{ 'component-cart.css' | asset_url | stylesheet_tag }}
      {{ 'component-totals.css' | asset_url | stylesheet_tag }}
      {{ 'component-price.css' | asset_url | stylesheet_tag }}
      {{ 'component-discounts.css' | asset_url | stylesheet_tag }}
    {%- endif -%}
  </head>
  <body>
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>
    <main id="MainContent" class="content-for-layout" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
   {%- if settings.cart_type == 'drawer' -%}
      {% comment %} {%- render 'cart-drawer' -%} {% endcomment %}
       {% section 'cart-drawer' %}
    {%- endif -%}
    {{ 'theme.js' | asset_url | script_tag }}
    {{ 'custom-add-to-cart.js' | asset_url | script_tag }}
    {% if template.suffix == 'comparison' %}
      {{ 'comparison-2-vs-5.js' | asset_url | script_tag }}
    {% endif %}
    {% if template.suffix == 'shower-envy-science' %}
      {{ 'shower-envy-science.js' | asset_url | script_tag }}
    {% endif %}
    {% if template.suffix == 'shower-envy-reviews' %}
      {{ 'se-reviews.js' | asset_url | script_tag }}
    {% endif %}
    {% if template.suffix == 'water-report' %}
      {{ 'water-report.js' | asset_url | script_tag }}
    {% endif %}
    {% if template.suffix == 'privacy-policy' %}
      {{ 'privacy-policy.js' | asset_url | script_tag }}
    {% endif %}

    {% if template.suffix == 'refund-policy' %}
      {{ 'refund-policy.js' | asset_url | script_tag }}
    {% endif %}

    {% if template.suffix == 'terms' %}
      {{ 'terms.js' | asset_url | script_tag }}
    {% endif %}

    {% if template.suffix == 'showerenvy-5-0-stationary' %}
      {{ 'se50-stationary.js' | asset_url | script_tag }}
    {% endif %}

    {% if template.suffix == 'showerenvy-2-product' %}
      {{ 'se20-product.js' | asset_url | script_tag }}
    {% endif %}

  </body>
</html>
