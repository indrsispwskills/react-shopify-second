<div class="screen" id="screenResults">

<!-- Results header -->
<div class="res-hdr">
  <div class="res-zip" id="resZipLabel">Water Report for 00000</div>
  <h1>Your Water Quality <em>Report</em></h1>
  <p class="res-sub" id="resSummary">We analyzed the public water records for your area. Here's what we found.</p>
</div>

<div class="wrap">

<!-- CARD 1: WATER QUALITY SCORE -->
<div class="rcard anim-up" id="cardGauge">
  <div class="rcard-title"><span class="emoji">&#128167;</span> Water Quality Score</div>
  <div class="rcard-sub">Based on EPA records for your water district. Lower scores indicate more contaminants detected.</div>
  <div class="gauge-wrap">
    <svg class="gauge-svg" viewBox="0 0 200 200">
      <circle cx="100" cy="100" r="85" fill="none" stroke="#E5E0D7" stroke-width="14" stroke-linecap="round" stroke-dasharray="401" stroke-dashoffset="133" transform="rotate(150 100 100)"/>
      <circle id="gaugeArc" cx="100" cy="100" r="85" fill="none" stroke="var(--red)" stroke-width="14" stroke-linecap="round" stroke-dasharray="401" stroke-dashoffset="401" transform="rotate(150 100 100)" style="transition:stroke-dashoffset 1.5s cubic-bezier(.22,1,.36,1),stroke 1s ease"/>
      <text id="gaugeNum" x="100" y="108" text-anchor="middle" font-size="48" fill="var(--ink)">—</text>
      <text x="100" y="128" text-anchor="middle" font-size="13" fill="var(--mute)">out of 100</text>
    </svg>
    <div class="gauge-info">
      <div class="gauge-grade" id="gaugeGrade">—</div>
      <p class="gauge-detail" id="gaugeDetail"></p>
      <div class="gauge-stats">
        <div class="gauge-stat"><div class="gs-num" id="gsContam">—</div><div class="gs-lab">Contaminants Found</div></div>
        <div class="gauge-stat"><div class="gs-num" id="gsExceed">—</div><div class="gs-lab">Exceed Guidelines</div></div>
        <div class="gauge-stat"><div class="gs-num" id="gsHardness">—</div><div class="gs-lab">Water Hardness (GPG)</div></div>
        <div class="gauge-stat"><div class="gs-num" id="gsPop">—</div><div class="gs-lab">People Affected</div></div>
      </div>
    </div>
  </div>
</div>

<!-- CARD 2: CONTAMINANTS DETECTED -->
<div class="rcard" id="cardContam">
  <div class="rcard-title"><span class="emoji">&#9888;&#65039;</span> Contaminants Detected</div>
  <div class="rcard-sub">These contaminants were detected in your water supply. Red bars show levels exceeding EPA guidelines or health goals.</div>
  <div class="contam-list" id="contamList">
    <!-- JS fills -->
  </div>
</div>

<!-- CARD 3: HAIR & SKIN DAMAGE -->
<div class="rcard" id="cardDamage">
  <div class="rcard-title"><span class="emoji">&#129520;</span> Impact on Hair &amp; Skin After 45</div>
  <div class="rcard-sub">Your water contaminants interact with the natural changes women experience during and after menopause — accelerating visible aging.</div>

  <!-- Body illustration with damage hotspots -->
  <div class="body-illust">
    <svg class="body-svg" viewBox="0 0 200 400" fill="none">
      <!-- Head / hair -->
      <ellipse cx="100" cy="52" rx="36" ry="42" fill="#F5EDE8" stroke="#D4C4B8" stroke-width="1"/>
      <!-- Hair -->
      <path d="M64 42 C64 20 80 10 100 10 C120 10 136 20 136 42 C136 34 130 24 120 22 C110 20 90 20 80 22 C70 24 64 34 64 42Z" fill="#8B7355" opacity=".6"/>
      <!-- Neck -->
      <rect x="88" y="90" width="24" height="20" rx="8" fill="#F5EDE8"/>
      <!-- Body -->
      <path d="M60 110 C60 104 75 100 100 100 C125 100 140 104 140 110 L145 240 C145 248 125 254 100 254 C75 254 55 248 55 240 Z" fill="#F5EDE8" stroke="#D4C4B8" stroke-width="1"/>
      <!-- Arms -->
      <path d="M60 115 L38 180 C36 186 40 190 44 188 L64 140" fill="#F5EDE8" stroke="#D4C4B8" stroke-width="1"/>
      <path d="M140 115 L162 180 C164 186 160 190 156 188 L136 140" fill="#F5EDE8" stroke="#D4C4B8" stroke-width="1"/>
      <!-- Legs -->
      <path d="M75 250 L68 360 C68 364 74 368 80 368 L82 360 L88 254" fill="#F5EDE8" stroke="#D4C4B8" stroke-width="1"/>
      <path d="M125 250 L132 360 C132 364 126 368 120 368 L118 360 L112 254" fill="#F5EDE8" stroke="#D4C4B8" stroke-width="1"/>

      <!-- DAMAGE HOTSPOTS (JS controls visibility via opacity) -->
      <!-- Hair thinning -->
      <g id="hsHair" class="hotspot" opacity="0">
        <circle cx="100" cy="26" r="22" fill="none" stroke="#D64545" stroke-width="2" stroke-dasharray="4 3"/>
        <circle cx="100" cy="26" r="22" fill="#D64545" opacity=".08"/>
      </g>
      <!-- Scalp -->
      <g id="hsScalp" class="hotspot" opacity="0">
        <circle cx="82" cy="38" r="10" fill="#E8873D" opacity=".2"/>
        <circle cx="82" cy="38" r="10" fill="none" stroke="#E8873D" stroke-width="1.5" stroke-dasharray="3 2"/>
      </g>
      <!-- Face / skin -->
      <g id="hsFace" class="hotspot" opacity="0">
        <ellipse cx="100" cy="60" rx="20" ry="24" fill="#D64545" opacity=".1"/>
        <ellipse cx="100" cy="60" rx="20" ry="24" fill="none" stroke="#D64545" stroke-width="1.5" stroke-dasharray="4 3"/>
      </g>
      <!-- Neck / chest -->
      <g id="hsNeck" class="hotspot" opacity="0">
        <rect x="80" y="92" width="40" height="28" rx="10" fill="#E8873D" opacity=".12"/>
        <rect x="80" y="92" width="40" height="28" rx="10" fill="none" stroke="#E8873D" stroke-width="1.5" stroke-dasharray="3 2"/>
      </g>
      <!-- Arms / body skin -->
      <g id="hsBody" class="hotspot" opacity="0">
        <ellipse cx="100" cy="180" rx="45" ry="60" fill="#B8956A" opacity=".08"/>
        <ellipse cx="100" cy="180" rx="45" ry="60" fill="none" stroke="#B8956A" stroke-width="1.5" stroke-dasharray="4 3"/>
      </g>
    </svg>
  </div>

  <div class="damage-grid" id="damageGrid">
    <!-- JS fills -->
  </div>
</div>

<!-- CARD 4: SHOWERENVY SOLUTION -->
<div class="rcard" id="cardSolution">
  <div class="rcard-title"><span class="emoji">&#128737;&#65039;</span> How ShowerEnvy 5.0 <em style="color:var(--sage);font-style:italic">Solves This</em></div>
  <p class="solution-intro">ShowerEnvy's 15-stage sequential filtration removes up to 99% of the contaminants found in your water — while infusing skin-nourishing vitamins A, C &amp; E with every shower.</p>

  <!-- Before / After snapshot -->
  <div class="filter-grid">
    <div class="filter-card before">
      <div class="fc-label">&#128680; Your Water Now</div>
      <div class="fc-val" id="fcBefore">—</div>
      <div class="fc-unit">contaminants detected</div>
    </div>
    <div class="filter-card after">
      <div class="fc-label">&#10004; With ShowerEnvy</div>
      <div class="fc-val" id="fcAfter">—</div>
      <div class="fc-unit">contaminants removed</div>
    </div>
  </div>

  <!-- Removal effectiveness bars -->
  <div style="font-size:15px;font-weight:700;margin-bottom:14px">Filtration Effectiveness</div>
  <div class="removal-list" id="removalList">
    <!-- JS fills -->
  </div>

  <!-- Vitamin infusion -->
  <div style="font-size:15px;font-weight:700;margin-top:28px;margin-bottom:12px">Plus: Vitamin Infusion With Every Shower</div>
  <div class="vit-row">
    <div class="vit-pill"><div class="vp-ico">&#129514;</div><div class="vp-name">Vitamin A</div><div class="vp-desc">Retinol complex supports collagen your skin loses after estrogen decline</div></div>
    <div class="vit-pill"><div class="vp-ico">&#127819;</div><div class="vp-name">Vitamin C</div><div class="vp-desc">Neutralizes chlorine &amp; provides antioxidant defense against free radicals</div></div>
    <div class="vit-pill"><div class="vp-ico">&#128167;</div><div class="vp-name">Vitamin E</div><div class="vp-desc">Repairs &amp; strengthens moisture barrier where menopause lets hydration escape</div></div>
  </div>
</div>

<!-- CTA -->
<div class="cta-card">
  <h2>{{ section.settings.cta_title }}</h2>
  <p>{{ section.settings.cta_text }}</p>
  <button class="cta-btn" onclick="window.location.href='{{ section.settings.cta_link }}'">{{ section.settings.cta_button_text }}</button>
  <div class="cta-trust">
    <span>&#128274; 60-Day Guarantee</span>
    <span>&#128666; Free Shipping</span>
    <span>&#9201; 30-Sec Install</span>
  </div>
</div>

</div><!-- /wrap -->
</div><!-- /screenResults -->

{% schema %}
{
  "name":"Water report results",
  "settings":[
    {"type":"html","id":"cta_title","label":"CTA title","default":"Protect Your Hair &amp; Skin <em>Today</em>"},
    {"type":"textarea","id":"cta_text","label":"CTA description","default":"Your water report shows real contamination risks. ShowerEnvy 5.0 removes them in 30 seconds flat — no plumber needed."},
    {"type":"text","id":"cta_button_text","label":"CTA button text","default":"💧 Shop ShowerEnvy 5.0 →"},
    {"type":"text","id":"cta_link","label":"CTA link","default":"ShowerEnvy_5_Sales_Page.html"}
  ],
  "presets":[{"name":"Water report results"}]
}
{% endschema %}
