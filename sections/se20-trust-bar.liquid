<!-- ═══ TRUST BAR — Animated Counters ═══ -->
<div id="trustBar" class="rv" style="display:flex;justify-content:center;gap:32px;flex-wrap:wrap;padding:24px 0;border-top:1px solid var(--bdr);border-bottom:1px solid var(--bdr);margin-bottom:56px;font-size:14px;color:var(--mut);text-align:center">
  <div><strong class="ctr" data-end="12400" data-suf="+" data-fmt="1" style="color:var(--gold);font-size:24px">0</strong><br>Women Trust ShowerEnvy</div>
