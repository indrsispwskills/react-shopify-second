      <div class="stat-box rv-scale rv-d2"><div class="stat-num counter" data-target="2.1" data-suffix="%" data-decimal="true" style="color:var(--gold)">0%</div><div class="stat-label">Annual Decline</div><div class="stat-sub">Collagen per postmenopausal year</div><div class="a-bar"><div class="a-bar-fill a-bar-fill--gold" style="--fill:42%"></div></div></div>
      <div class="stat-box rv-scale rv-d3"><div class="stat-num counter" data-target="1.1" data-suffix="%" data-decimal="true" style="color:var(--gold)">0%</div><div class="stat-label">Thickness Loss</div><div class="stat-sub">Skin thickness decrease per year</div><div class="a-bar"><div class="a-bar-fill a-bar-fill--gold" style="--fill:30%"></div></div></div>
