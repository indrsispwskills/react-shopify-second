<div class="page">
  <section class="featured rv">
    <h2>{{ section.settings.heading }}</h2>
    <p class="featured-sub">{{ section.settings.subheading }}</p>
    <div class="featured-grid">
      {% for block in section.blocks %}
        <div class="featured-card rv-d{{ forloop.index }} rv">
          <div class="featured-ph" {% if block.settings.border_color != blank %}style="border-color:{{ block.settings.border_color }}"{% endif %}>
            <span>📸</span>
            <span {% if block.settings.accent_color != blank %}style="color:{{ block.settings.accent_color }}"{% endif %}>{{ block.settings.photo_label }}</span>
            <span {% if block.settings.accent_color != blank %}style="color:{{ block.settings.accent_color }}"{% endif %}>{{ block.settings.photo_subtext }}</span>
          </div>
          <div class="featured-quote">"{{ block.settings.quote }}"</div>
          <div class="featured-meta"><span class="featured-name">{{ block.settings.name_age }}</span><span class="featured-product" style="color:{{ block.settings.product_text_color }};background:{{ block.settings.product_bg_color }}">{{ block.settings.product_label }}</span></div>
        </div>
      {% endfor %}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "SE reviews featured",
  "settings": [
    {"type":"text","id":"heading","label":"Heading","default":"Featured Transformations"},
    {"type":"textarea","id":"subheading","label":"Subheading","default":"Real customers, real photos, real results. Upload your own transformation for a chance to be featured."}
  ],
  "blocks": [
    {"type":"card","name":"Featured card","settings":[{"type":"text","id":"photo_label","label":"Photo label","default":"Customer Photo"},{"type":"text","id":"photo_subtext","label":"Photo subtext","default":"Before & after hair — woman 50+"},{"type":"textarea","id":"quote","label":"Quote","default":"I used to have thick beautiful hair and now I had old lady hair. Three months with ShowerEnvy and my stylist literally gasped."},{"type":"text","id":"name_age","label":"Name and age","default":"Linda R., 57"},{"type":"text","id":"product_label","label":"Product label","default":"2.0 Handheld"},{"type":"color","id":"product_text_color","label":"Product text color","default":"#5E8A6A"},{"type":"color","id":"product_bg_color","label":"Product background color","default":"#F0F7F2"},{"type":"color","id":"border_color","label":"Photo border color"},{"type":"color","id":"accent_color","label":"Photo text accent"}]}
  ],
  "max_blocks": 3,
  "presets": [{"name":"SE reviews featured","blocks":[{"type":"card"},{"type":"card","settings":{"quote":"My skin was so dry it would crack and bleed. Within two weeks of filtered showers, my dermatologist asked what I changed.","name_age":"Patricia M., 54","product_label":"5.0 Stationary","product_text_color":"#B08642","product_bg_color":"#FBF6ED","border_color":"#C25D4E","accent_color":"#C25D4E","photo_subtext":"Skin transformation — crepey to hydrated"}},{"type":"card","settings":{"quote":"My $180 salon color used to fade in two weeks. Now it holds the full six weeks. The chlorine was stripping it every single shower.","name_age":"Karen S., 49","product_label":"2.0 Handheld","border_color":"#B08642","accent_color":"#B08642","photo_subtext":"Color-treated hair — 6-week hold"}}]}]
}
{% endschema %}
