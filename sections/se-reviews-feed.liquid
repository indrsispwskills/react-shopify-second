<div class="filter-bar" id="filterBar">
  <div class="page">
    <div class="filter-inner">
      <span class="filter-label">Filter:</span>
      <button class="filter-btn act" data-filter="all">All Reviews</button>
      <div class="filter-sep"></div>
      <button class="filter-btn" data-filter="p20">2.0 Handheld</button>
      <button class="filter-btn" data-filter="p50">5.0 Stationary</button>
      <div class="filter-sep"></div>
      <button class="filter-btn" data-filter="hair">Hair Issues</button>
      <button class="filter-btn" data-filter="skin">Skin Issues</button>
      <button class="filter-btn" data-filter="shared">Shared / Multi-Buy</button>
      <button class="filter-btn" data-filter="ba">Before &amp; After</button>
      <div class="filter-sep"></div>
      <select class="sort-select" id="sortSelect">
        <option value="recent">Most Recent</option>
        <option value="helpful">Most Helpful</option>
        <option value="rating-high">Highest Rated</option>
        <option value="rating-low">Lowest Rated</option>
      </select>
      <div class="filter-count">Showing <b id="showCount">48</b> of <b>{{ section.settings.total_reviews }}</b></div>
    </div>
  </div>
</div>

<div class="page">
  <div class="reviews-grid" id="reviewsGrid"></div>

  <div class="load-more-wrap">
    <button class="load-more" id="loadMore">{{ section.settings.load_more_label }}</button>
    <div class="load-progress">Showing <b id="loadShown">48</b> of <b>{{ section.settings.total_reviews }}</b> reviews</div>
    <div class="progress-bar-wrap"><div class="progress-bar-fill" id="progressFill" style="width:3.6%"></div></div>
  </div>
</div>
{% schema %}
{
  "name": "SE reviews feed",
  "settings": [
    {"type":"text","id":"total_reviews","label":"Total reviews label","default":"1,347"},
    {"type":"text","id":"load_more_label","label":"Load more button","default":"Load More Reviews"}
  ],
  "presets": [{"name":"SE reviews feed"}]
}
{% endschema %}
