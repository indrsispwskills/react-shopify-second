<section id="reviews" class="reveal">
  <div class="wrap">
  <div class="s-head"><div class="s-tag" style="color:var(--gold)">SOCIAL PROOF</div><h2 class="s-title">{{ section.settings.title }}</h2></div>
  <div class="reviews-grid">
    {% for block in section.blocks %}{% if block.type == 'review' %}<div class="rev-card" {{ block.shopify_attributes }}><div class="rev-stars">★★★★★</div><p class="rev-quote">“{{ block.settings.quote }}”</p><div class="rev-meta">{{ block.settings.meta }}</div></div>{% endif %}{% endfor %}
  </div>
  </div>
</section>
{% schema %}
{
  "name":"Comparison reviews",
  "settings":[{"type":"text","id":"title","label":"Title","default":"Real Women, Real Results"}],
  "blocks":[{"type":"review","name":"Review","settings":[{"type":"text","id":"quote","label":"Quote","default":"My hair finally stopped feeling like straw."},{"type":"text","id":"meta","label":"Meta","default":"— Sarah, 52 · 5.0 user"}]}],
  "presets":[{"name":"Comparison reviews","blocks":[{"type":"review","settings":{"quote":"My hair finally stopped feeling like straw.","meta":"— Sarah, 52 · 5.0 user"}},{"type":"review","settings":{"quote":"The 2.0 made my scalp less itchy in one week.","meta":"— Tina, 47 · 2.0 user"}},{"type":"review","settings":{"quote":"Wish I knew this 10 years ago.","meta":"— Monica, 58 · 5.0 user"}}]}]
}
{% endschema %}
