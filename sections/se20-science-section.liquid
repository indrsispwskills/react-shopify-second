<!-- ═══ SCIENCE — Animated particles ═══ -->
<section id="science" class="sec" style="padding:36px 28px;background:linear-gradient(145deg,var(--cream),#fff);border-radius:28px;border:1px solid var(--bdr);box-shadow:var(--sh-sm);position:relative;overflow:hidden">
  <div class="particles">
    <span style="--x:10%;--y:20%;--tx:40px;--ty:-60px;--s:5px;--c:rgba(176,134,66,.12);--d:5s;--dl:0s"></span>
    <span style="--x:80%;--y:30%;--tx:-30px;--ty:-50px;--s:4px;--c:rgba(194,93,78,.1);--d:6s;--dl:1s"></span>
    <span style="--x:50%;--y:70%;--tx:20px;--ty:-40px;--s:6px;--c:rgba(94,138,106,.1);--d:7s;--dl:2s"></span>
    <span style="--x:20%;--y:80%;--tx:50px;--ty:-30px;--s:3px;--c:rgba(176,134,66,.08);--d:5.5s;--dl:.5s"></span>
  </div>
  <div class="sh rv" style="position:relative;z-index:1"><div class="tag" style="color:var(--rose)">THE SCIENCE</div><h2>Why Your Water Matters More After 45</h2><p>Two forces working against your hair and skin — one from inside, one from outside. Only one is in your control.</p></div>

  <div class="grid-3" style="gap:0;margin-bottom:28px;position:relative;z-index:1">
    <div class="rv rv-d1" style="padding:24px;border-radius:20px 0 0 20px;background:var(--gold3);text-align:center;border:1px solid rgba(176,134,66,.12);border-right:none">
      <div style="font-size:36px;margin-bottom:10px;animation:float 3s ease-in-out infinite">🧬</div>
      <div class="tag" style="color:var(--gold)">HORMONAL SHIFT</div>
      <h4 style="font-size:17px;margin-bottom:8px">Less Oil, Less Protection</h4>
      <p style="font-size:14px;color:var(--mut);line-height:1.6">Estrogen decline reduces sebum by 30–50%. Your scalp and skin lose their natural barrier.</p>
    </div>
    <div class="rv rv-d2" style="display:flex;align-items:center;justify-content:center;padding:0 16px;background:linear-gradient(180deg,var(--gold3),var(--redl))">
      <span style="font-family:var(--fh);font-size:36px;font-weight:700;color:var(--red);animation:scaleIn 1s var(--eo)">+</span>
    </div>
    <div class="rv rv-d3" style="padding:24px;border-radius:0 20px 20px 0;background:var(--redl);text-align:center;border:1px solid rgba(220,38,38,.08);border-left:none">
      <div style="font-size:36px;margin-bottom:10px;animation:float 3s ease-in-out infinite .5s">🚿</div>
      <div class="tag" style="color:var(--red)">UNFILTERED WATER</div>
      <h4 style="font-size:17px;margin-bottom:8px">Remaining Oil Stripped</h4>
      <p style="font-size:14px;color:var(--mut);line-height:1.6">Chlorine strips what little oil your body still produces. Hard water coats follicles in mineral film.</p>
    </div>
  </div>

  <div class="grid-2" style="gap:16px;margin-bottom:24px;max-width:560px;margin-left:auto;margin-right:auto;position:relative;z-index:1">
    <div class="rv-scale" style="text-align:center;padding:20px;border-radius:18px;background:#fff;border:1px solid var(--bdr);box-shadow:var(--sh-sm)"><div style="font-family:var(--fh);font-size:36px;font-weight:700;color:var(--red)">85%</div><div style="font-size:14px;font-weight:600;color:var(--ink);margin-top:4px">U.S. Homes Have Hard Water</div></div>
    <div class="rv-scale" style="text-align:center;padding:20px;border-radius:18px;background:#fff;border:1px solid var(--bdr);box-shadow:var(--sh-sm);transition-delay:.15s"><div style="font-family:var(--fh);font-size:36px;font-weight:700;color:var(--gold)">30%</div><div style="font-size:14px;font-weight:600;color:var(--ink);margin-top:4px">Collagen Lost in 5 Years</div><div style="font-size:14px;color:var(--mut)">Post-menopause</div></div>
  </div>
  <div class="rv" style="padding:18px 24px;border-radius:16px;background:var(--sage3);border:1px solid rgba(94,138,106,.12);max-width:600px;margin:0 auto;position:relative;z-index:1"><p style="font-family:var(--fh);font-size:17px;font-weight:600;color:var(--ink);font-style:italic;text-align:center;line-height:1.5;margin:0">You can't stop hormonal changes. But you <em>can</em> stop your water from making them worse.</p></div>
</section>

<div class="divider rv"><span>✦</span></div>


